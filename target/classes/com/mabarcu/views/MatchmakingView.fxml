<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.mabarcu.controllers.MatchmakingController"
            styleClass="root-bg"
            prefWidth="1200"
            prefHeight="760">

    <left>
        <fx:include source="Sidebar.fxml"/>
    </left>

    <center>
        <StackPane>
            <Circle radius="300"
                    fill="#0f1f16"
                    opacity="0.2"
                    StackPane.alignment="BOTTOM_RIGHT"
                    translateX="100"
                    translateY="100"
                    mouseTransparent="true"/>

            <VBox spacing="24" styleClass="page">
                <padding>
                    <Insets top="32" right="36" bottom="32" left="36"/>
                </padding>

                <!-- Header -->
                <VBox spacing="4">
                    <Label text="⚔  Matchmaking Hub" styleClass="page-title"/>
                    <Label text="Filter player berdasarkan game, rank, role, dan region untuk mencari teman mabar yang cocok."
                           styleClass="muted"/>
                </VBox>

                <!-- Filter Bar -->
                <HBox spacing="14"
                      alignment="CENTER_LEFT"
                      styleClass="panel"
                      prefHeight="76"
                      minHeight="76">
                    <padding>
                        <Insets top="12" right="20" bottom="12" left="20"/>
                    </padding>

                    <ComboBox fx:id="gameFilter"
                              promptText="Game"
                              styleClass="combo-box"
                              prefWidth="170"
                              prefHeight="40"/>

                    <ComboBox fx:id="rankFilter"
                              promptText="Rank"
                              styleClass="combo-box"
                              prefWidth="150"
                              prefHeight="40"/>

                    <ComboBox fx:id="roleFilter"
                              promptText="Role"
                              styleClass="combo-box"
                              prefWidth="150"
                              prefHeight="40"/>

                    <ComboBox fx:id="regionFilter"
                              promptText="Region"
                              styleClass="combo-box"
                              prefWidth="150"
                              prefHeight="40"/>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button text="🔍  Search"
                            onAction="#search"
                            styleClass="primary-green-btn"
                            prefWidth="130"
                            prefHeight="40"/>
                </HBox>

                <!-- Info Bar -->
                <Label fx:id="infoLabel"
                       styleClass="stat-bar"
                       maxWidth="Infinity"
                       prefHeight="42">
                    <padding>
                        <Insets left="16" right="16"/>
                    </padding>
                </Label>

                <!-- Results List -->
                <ListView fx:id="resultList"
                          VBox.vgrow="ALWAYS"
                          styleClass="list-view"/>

                <!-- Action Buttons -->
                <HBox spacing="16"
                      alignment="CENTER_LEFT"
                      styleClass="action-footer">

                    <Button text="⚔  Invite Selected Team"
                            onAction="#inviteSelected"
                            styleClass="primary-green-btn"
                            prefHeight="44"
                            prefWidth="220"/>

                    <Button text="➕  Follow Selected User"
                            onAction="#followSelected"
                            styleClass="secondary-flat-btn"
                            prefHeight="44"
                            prefWidth="220"/>

                    <Button text="👁  View Profile"
                            onAction="#viewProfile"
                            styleClass="ghost-btn"
                            prefHeight="44"
                            prefWidth="220"/>
                </HBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.mabarcu.controllers.ProfileController"
            styleClass="root-bg"
            prefWidth="1200"
            prefHeight="760">

    <left>
        <fx:include source="Sidebar.fxml"/>
    </left>

    <center>
        <ScrollPane fitToWidth="true"
                    styleClass="main-scrollpane"
                    vbarPolicy="AS_NEEDED">

            <VBox spacing="24" styleClass="page">
                <padding>
                    <Insets top="32" right="36" bottom="32" left="36"/>
                </padding>

                <!-- Hero Banner -->
                <VBox spacing="14" styleClass="hero">
                    <VBox spacing="4">
                        <Label fx:id="profileHeader"
                               text="Display Name • @username"
                               styleClass="hero-title"/>

                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Circle radius="5" fill="#52b788"/>
                            <Label text="STATUS:" styleClass="hero-status-tag"/>
                            <Label text="Online" styleClass="success-text" fx:id="lblStatus"
                                   style="-fx-font-weight: 700;"/>
                        </HBox>

                        <HBox spacing="16" alignment="CENTER_LEFT" style="-fx-padding: 8 0 0 0;">
                            <HBox spacing="4" alignment="CENTER_LEFT">
                                <Label fx:id="followersLabel" text="0" styleClass="hero-title" style="-fx-font-size: 16px;"/>
                                <Label text="Followers" styleClass="muted"/>
                            </HBox>
                            <HBox spacing="4" alignment="CENTER_LEFT">
                                <Label fx:id="followingLabel" text="0" styleClass="hero-title" style="-fx-font-size: 16px;"/>
                                <Label text="Following" styleClass="muted"/>
                            </HBox>
                            <HBox spacing="4" alignment="CENTER_LEFT">
                                <Label fx:id="friendsLabel" text="0" styleClass="hero-title" style="-fx-font-size: 16px;"/>
                                <Label text="Friends" styleClass="muted"/>
                            </HBox>
                        </HBox>
                    </VBox>

                    <Separator styleClass="hero-divider"/>

                    <HBox spacing="18">
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="FAVORITE GAME" styleClass="input-label"/>
                            <Label fx:id="gameValue" text="-" styleClass="section-title"/>
                        </VBox>

                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="RANK" styleClass="input-label"/>
                            <Label fx:id="rankValue" text="-" styleClass="section-title"/>
                        </VBox>

                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="ROLE" styleClass="input-label"/>
                            <Label fx:id="roleValue" text="-" styleClass="section-title"/>
                        </VBox>

                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="REGION" styleClass="input-label"/>
                            <Label fx:id="regionValue" text="-" styleClass="section-title"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Main Content -->
                <HBox spacing="20" VBox.vgrow="ALWAYS">

                    <!-- Edit Profile Form -->
                    <VBox spacing="16" styleClass="panel" HBox.hgrow="ALWAYS">
                        <Label text="Edit Gamer Profile" styleClass="section-title"/>

                        <GridPane hgap="16" vgap="16">
                            <columnConstraints>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="50.0"/>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="50.0"/>
                            </columnConstraints>

                            <children>
                                <VBox spacing="6" GridPane.rowIndex="0" GridPane.columnIndex="0">
                                    <Label text="DISPLAY NAME" styleClass="input-label"/>
                                    <TextField fx:id="displayNameField" styleClass="input" prefHeight="40"/>
                                </VBox>

                                <VBox spacing="6" GridPane.rowIndex="0" GridPane.columnIndex="1">
                                    <Label text="USERNAME" styleClass="input-label"/>
                                    <TextField fx:id="usernameField" styleClass="input" prefHeight="40"/>
                                </VBox>

                                <VBox spacing="6" GridPane.rowIndex="1" GridPane.columnIndex="0">
                                    <Label text="FAVORITE GAME" styleClass="input-label"/>
                                    <TextField fx:id="gameField" styleClass="input" prefHeight="40"/>
                                </VBox>

                                <VBox spacing="6" GridPane.rowIndex="1" GridPane.columnIndex="1">
                                    <Label text="RANK" styleClass="input-label"/>
                                    <TextField fx:id="rankField" styleClass="input" prefHeight="40"/>
                                </VBox>

                                <VBox spacing="6" GridPane.rowIndex="2" GridPane.columnIndex="0">
                                    <Label text="PREFERRED ROLE" styleClass="input-label"/>
                                    <TextField fx:id="roleField" styleClass="input" prefHeight="40"/>
                                </VBox>

                                <VBox spacing="6" GridPane.rowIndex="2" GridPane.columnIndex="1">
                                    <Label text="REGION" styleClass="input-label"/>
                                    <TextField fx:id="regionField" styleClass="input" prefHeight="40"/>
                                </VBox>

                                <VBox spacing="6" GridPane.rowIndex="3" GridPane.columnIndex="0"
                                      GridPane.columnSpan="2">
                                    <Label text="GENDER" styleClass="input-label"/>
                                    <TextField fx:id="genderField" styleClass="input" prefHeight="40"/>
                                </VBox>

                                <VBox spacing="6" GridPane.rowIndex="4" GridPane.columnIndex="0"
                                      GridPane.columnSpan="2">
                                    <Label text="SHORT BIO" styleClass="input-label"/>
                                    <TextArea fx:id="bioArea"
                                              prefRowCount="3"
                                              styleClass="input"
                                              wrapText="true"/>
                                </VBox>
                            </children>
                        </GridPane>

                        <Separator styleClass="hero-divider"/>

                        <HBox spacing="14" alignment="CENTER_LEFT">
                            <Button text="✦  Save Changes"
                                    onAction="#saveProfile"
                                    styleClass="primary-btn"
                                    prefHeight="40"
                                    prefWidth="160"/>

                            <Button text="⟳  Refresh"
                                    onAction="#refreshProfile"
                                    styleClass="secondary-flat-btn"
                                    prefHeight="40"
                                    prefWidth="120"/>

                            <Label fx:id="saveMsg" styleClass="message-label"/>
                        </HBox>
                    </VBox>

                    <!-- Activity Panel -->
                    <VBox spacing="12" styleClass="panel" prefWidth="340" minWidth="300">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="📋" style="-fx-font-size: 14px;"/>
                            <Label text="Recent Match &amp; Party History" styleClass="section-title"/>
                        </HBox>
                        <ListView fx:id="activityList" VBox.vgrow="ALWAYS" styleClass="list-view"/>
                    </VBox>

                </HBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
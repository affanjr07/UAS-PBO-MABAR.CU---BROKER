<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.mabarcu.controllers.PartyRoomController"
            prefWidth="1200"
            prefHeight="760"
            styleClass="root-bg">

    <left>
        <fx:include source="Sidebar.fxml"/>
    </left>

    <center>
        <StackPane>
            <Circle radius="320"
                    fill="#0f1f16"
                    opacity="0.2"
                    StackPane.alignment="BOTTOM_RIGHT"
                    translateX="100"
                    translateY="100"
                    mouseTransparent="true"/>

            <VBox spacing="24" styleClass="page">
                <padding>
                    <Insets top="32" right="36" bottom="32" left="36"/>
                </padding>

                <!-- Header -->
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="⚑  Party Room Hub" styleClass="page-title"/>
                        <Label text="Buat room sesuai game, rank, role, dan kumpulkan squad kamu."
                               styleClass="muted"/>
                    </VBox>

                    <Button text="⟳  Refresh"
                            onAction="#refreshRooms"
                            styleClass="secondary-flat-btn"
                            prefHeight="40"
                            prefWidth="130"/>
                </HBox>

                <!-- Main 3-Column Layout -->
                <HBox spacing="20" VBox.vgrow="ALWAYS">

                    <!-- Left: Create Room Form -->
                    <VBox spacing="14" prefWidth="300" minWidth="280" styleClass="panel">
                        <padding>
                            <Insets top="20" right="20" bottom="20" left="20"/>
                        </padding>

                        <Label text="Create Room" styleClass="section-title"/>

                        <ScrollPane fitToWidth="true"
                                    hbarPolicy="NEVER"
                                    vbarPolicy="AS_NEEDED"
                                    VBox.vgrow="ALWAYS"
                                    style="-fx-background-color: transparent; -fx-background: transparent;">

                            <VBox spacing="14">

                                <VBox spacing="5">
                                    <Label text="GAME" styleClass="input-label"/>
                                    <ComboBox fx:id="gameBox"
                                              maxWidth="Infinity"
                                              styleClass="combo-box"
                                              prefHeight="40"/>
                                </VBox>

                                <VBox spacing="5">
                                    <Label text="RANK" styleClass="input-label"/>
                                    <ComboBox fx:id="rankBox"
                                              maxWidth="Infinity"
                                              styleClass="combo-box"
                                              prefHeight="40"/>
                                </VBox>

                                <VBox spacing="5">
                                    <Label text="ROLE DIBUTUHKAN" styleClass="input-label"/>
                                    <ComboBox fx:id="roleBox"
                                              maxWidth="Infinity"
                                              styleClass="combo-box"
                                              prefHeight="40"/>
                                </VBox>

                                <VBox spacing="5">
                                    <Label text="TIPE ROOM" styleClass="input-label"/>
                                    <ComboBox fx:id="typeBox"
                                              maxWidth="Infinity"
                                              styleClass="combo-box"
                                              prefHeight="40"/>
                                </VBox>

                                <VBox spacing="5">
                                    <Label text="MAX PLAYER" styleClass="input-label"/>
                                    <Spinner fx:id="maxPlayerSpinner"
                                             editable="true"
                                             maxWidth="Infinity"
                                             styleClass="spinner"
                                             prefHeight="40"/>
                                </VBox>

                            </VBox>
                        </ScrollPane>

                        <Button text="✦  Create Room"
                                onAction="#createRoom"
                                maxWidth="Infinity"
                                styleClass="primary-green-btn"
                                prefHeight="42"/>

                        <!-- Console Info -->
                        <VBox spacing="6" styleClass="stat-bar">
                            <Label text="CONSOLE"
                                   style="-fx-text-fill: #3a6b52;
                                          -fx-font-size: 9px;
                                          -fx-font-weight: 800;"/>

                            <Label fx:id="infoLabel"
                                   text="Pilih atau buat room baru untuk memulai sesi."
                                   wrapText="true"
                                   style="-fx-text-fill: #52b788;
                                          -fx-font-size: 11px;
                                          -fx-font-family: 'Cascadia Code', 'Consolas', monospace;"/>
                        </VBox>
                    </VBox>

                    <!-- Center: Room List -->
                    <VBox spacing="14" styleClass="panel" HBox.hgrow="ALWAYS">
                        <padding>
                            <Insets top="20" right="20" bottom="20" left="20"/>
                        </padding>

                        <Label text="Available Rooms" styleClass="section-title"/>

                        <ListView fx:id="roomList"
                                  VBox.vgrow="ALWAYS"
                                  styleClass="list-view"/>

                        <HBox spacing="12" styleClass="action-footer">
                            <Button text="⚔  Join Selected"
                                    onAction="#joinRoom"
                                    maxWidth="Infinity"
                                    HBox.hgrow="ALWAYS"
                                    styleClass="primary-green-btn"
                                    prefHeight="42"/>

                            <Button text="Leave Room"
                                    onAction="#leaveRoom"
                                    maxWidth="Infinity"
                                    HBox.hgrow="ALWAYS"
                                    styleClass="secondary-flat-btn"
                                    prefHeight="42"/>
                        </HBox>
                    </VBox>

                    <!-- Right: Members + Chat -->
                    <VBox spacing="16" prefWidth="340" minWidth="300">

                        <VBox spacing="12" styleClass="panel" prefHeight="220">
                            <padding>
                                <Insets top="16" right="16" bottom="16" left="16"/>
                            </padding>

                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label text="👥" style="-fx-font-size: 14px;"/>
                                <Label text="Room Members" styleClass="section-title"/>
                            </HBox>

                            <ListView fx:id="memberList"
                                      VBox.vgrow="ALWAYS"
                                      styleClass="list-view"/>
                        </VBox>

                        <VBox spacing="12" styleClass="panel" VBox.vgrow="ALWAYS">
                            <padding>
                                <Insets top="16" right="16" bottom="16" left="16"/>
                            </padding>

                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Circle radius="4" fill="#52b788"/>
                                <Label text="Room Tactical Chat" styleClass="section-title"/>
                            </HBox>

                            <ListView fx:id="roomChatList"
                                      VBox.vgrow="ALWAYS"
                                      styleClass="chat-list-view"/>

                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <TextField fx:id="roomMessageField"
                                           promptText="Ketik chat room..."
                                           HBox.hgrow="ALWAYS"
                                           styleClass="input"
                                           prefHeight="40"
                                           onAction="#sendRoomMessage"/>

                                <Button text="SEND"
                                        onAction="#sendRoomMessage"
                                        styleClass="primary-green-btn"
                                        prefHeight="40"
                                        prefWidth="80"/>
                            </HBox>
                        </VBox>
                    </VBox>

                </HBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" prefWidth="240" styleClass="sidebar"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.mabarcu.controllers.SidebarController">

    <padding>
        <Insets top="30" right="16" bottom="30" left="16"/>
    </padding>

    <VBox spacing="4" styleClass="sidebar-divider">
        <HBox alignment="CENTER_LEFT" spacing="8">
            <StackPane style="-fx-background-color: #52b788; -fx-background-radius: 4;"
                       prefWidth="10"
                       prefHeight="10"/>
            <Label text="MABAR.CU" styleClass="logo"/>
        </HBox>

        <Label text="Gaming Broker Platform"
               styleClass="muted"
               style="-fx-font-size: 11px;"/>

        <Region prefHeight="15"/>
    </VBox>

    <VBox spacing="6" VBox.vgrow="ALWAYS">
        <Button text="Dashboard"
                onAction="#goDashboard"
                styleClass="nav-btn"
                maxWidth="Infinity"
                alignment="BASELINE_LEFT"/>

        <Button text="Matchmaking"
                onAction="#goMatchmaking"
                styleClass="nav-btn"
                maxWidth="Infinity"
                alignment="BASELINE_LEFT"/>

        <Button text="Profile"
                onAction="#goProfile"
                styleClass="nav-btn"
                maxWidth="Infinity"
                alignment="BASELINE_LEFT"/>

        <Button text="Chat"
                onAction="#goChat"
                styleClass="nav-btn"
                maxWidth="Infinity"
                alignment="BASELINE_LEFT"/>

        <Button text="Party Room"
                onAction="#goParty"
                styleClass="nav-btn"
                maxWidth="Infinity"
                alignment="BASELINE_LEFT"/>

        <Button text="Friendlist"
                onAction="#goFriends"
                styleClass="nav-btn"
                maxWidth="Infinity"
                alignment="BASELINE_LEFT"/>
    </VBox>

    <Button text="Logout"
            onAction="#logout"
            styleClass="danger-btn"
            maxWidth="Infinity"/>
</VBox>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.mabarcu.controllers.DashboardController"
            prefWidth="1200"
            prefHeight="760"
            styleClass="root-bg">

    <left>
        <fx:include source="Sidebar.fxml"/>
    </left>

    <center>
        <StackPane>
            <Circle radius="300"
                    fill="#14241c"
                    opacity="0.2"
                    StackPane.alignment="BOTTOM_RIGHT"
                    translateX="100"
                    translateY="100"
                    mouseTransparent="true"/>

            <VBox spacing="24" styleClass="page">
                <padding>
                    <Insets top="30" right="30" bottom="30" left="30"/>
                </padding>

                <VBox spacing="4">
                    <Label fx:id="welcomeLabel"
                           text="Halo, Player"
                           styleClass="page-title"/>

                    <Label text="Pantau player online, notifikasi, dan aktivitas akun kamu secara real-time."
                           styleClass="muted"/>
                </VBox>

                <HBox spacing="20" VBox.vgrow="ALWAYS">

                    <VBox spacing="14" styleClass="panel" HBox.hgrow="ALWAYS">
                        <VBox spacing="2">
                            <Label text="Online Players" styleClass="stat-label-alt"/>
                            <HBox alignment="BASELINE_LEFT" spacing="6">
                                <Label fx:id="onlineCountLabel" text="0" styleClass="stat-value"/>
                                <Label text="active" styleClass="muted" style="-fx-font-size: 11px;"/>
                            </HBox>
                        </VBox>

                        <ListView fx:id="onlineList"
                                  VBox.vgrow="ALWAYS"
                                  styleClass="list-view"/>
                    </VBox>

                    <VBox spacing="14" styleClass="panel" HBox.hgrow="ALWAYS">
                        <VBox spacing="2">
                            <Label text="Offline Players" styleClass="stat-label"/>
                            <HBox alignment="BASELINE_LEFT" spacing="6">
                                <Label fx:id="offlineCountLabel"
                                       text="0"
                                       styleClass="stat-value"
                                       style="-fx-text-fill: #52796f;"/>
                                <Label text="inactive" styleClass="muted" style="-fx-font-size: 11px;"/>
                            </HBox>
                        </VBox>

                        <ListView fx:id="offlineList"
                                  VBox.vgrow="ALWAYS"
                                  styleClass="list-view"/>
                    </VBox>

                    <VBox spacing="16" HBox.hgrow="ALWAYS">

                        <VBox spacing="10" styleClass="panel" VBox.vgrow="ALWAYS">
                            <Label text="Notifications" styleClass="section-title"/>
                            <ListView fx:id="notificationList"
                                      VBox.vgrow="ALWAYS"
                                      styleClass="list-view"/>
                        </VBox>

                        <VBox spacing="10" styleClass="panel" VBox.vgrow="ALWAYS">
                            <Label text="Activities Logs" styleClass="section-title"/>
                            <ListView fx:id="activityList"
                                      VBox.vgrow="ALWAYS"
                                      styleClass="list-view"/>
                        </VBox>
                    </VBox>

                </HBox>

                <HBox alignment="CENTER_RIGHT" styleClass="action-footer">
                    <Button text="Refresh Dashboard"
                            onAction="#refresh"
                            prefHeight="38"
                            prefWidth="180"
                            styleClass="primary-green-btn"/>
                </HBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
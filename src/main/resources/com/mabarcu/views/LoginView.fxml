<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.mabarcu.controllers.LoginController" styleClass="root-bg" prefWidth="1000" prefHeight="650">
  <center>
    <StackPane BorderPane.alignment="CENTER">

      <StackPane mouseTransparent="true" maxWidth="Infinity" maxHeight="Infinity">
        <Circle radius="280" fill="#14241c" opacity="0.6" StackPane.alignment="TOP_LEFT" translateX="-80" translateY="-80"/>
        <Circle radius="220" fill="#1b3a2b" opacity="0.4" StackPane.alignment="BOTTOM_RIGHT" translateX="80" translateY="80"/>
      </StackPane>

      <padding>
        <Insets top="40" right="40" bottom="40" left="40" />
      </padding>

      <VBox alignment="CENTER" spacing="24" styleClass="login-card" maxWidth="400" maxHeight="520">
        <padding>
          <Insets top="35" right="35" bottom="35" left="35" />
        </padding>

        <VBox alignment="CENTER" spacing="6">
          <Label text="MABAR.CU" styleClass="brand-title" />
          <Label text="Find teammates • Party room • Chat • Friendlist" styleClass="muted" alignment="CENTER" textAlignment="CENTER" wrapText="true" />
        </VBox>

        <Region prefHeight="5" />

        <VBox spacing="14" maxWidth="Infinity">
          <VBox spacing="6">
            <Label text="Username or Email" styleClass="input-label"/>
            <TextField fx:id="usernameField" promptText="Enter your username..." styleClass="modern-input" prefHeight="42" />
          </VBox>

          <VBox spacing="6">
            <Label text="Password" styleClass="input-label"/>
            <PasswordField fx:id="passwordField" promptText="Enter your password..." styleClass="modern-input" prefHeight="42" />
          </VBox>
        </VBox>

        <Region prefHeight="5" />

        <VBox spacing="14" maxWidth="Infinity" alignment="CENTER">
          <Button text="Sign In" onAction="#login" styleClass="primary-green-btn" maxWidth="Infinity" prefHeight="42" />

          <HBox alignment="CENTER" spacing="12" maxWidth="Infinity">
            <Button text="Create Account" onAction="#register" styleClass="secondary-flat-btn" HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="38" />
            <Button text="Forgot Password?" onAction="#forgotPassword" styleClass="secondary-flat-btn" HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="38" />
          </HBox>
        </VBox>

        <Label fx:id="messageLabel" styleClass="message-label" wrapText="true" alignment="CENTER" textAlignment="CENTER" maxWidth="Infinity" />
      </VBox>
    </StackPane>
  </center>
</BorderPane>